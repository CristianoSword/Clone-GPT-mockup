<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clone GPT Mockup</title>
    <link rel="stylesheet" href="/styles.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif']
            }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen text-zinc-100">
    <main class="mx-auto flex min-h-screen max-w-6xl flex-col p-4 md:p-6">
      <section class="flex min-h-0 flex-1 overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl backdrop-blur">
        <aside class="hidden w-72 shrink-0 border-r border-white/10 bg-black/20 p-5 lg:block">
          <div class="mb-8">
            <h1 class="text-xl font-semibold">Clone GPT</h1>
            <p class="mt-2 text-sm text-zinc-400">Chat local, HTMX e EJS</p>
          </div>
          <div class="space-y-3 text-sm text-zinc-300">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">SPA-like sem reload completo</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Resposta mock/echo local</div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Express + TypeScript</div>
          </div>
        </aside>
        <section class="flex min-h-0 flex-1 flex-col">
          <header class="border-b border-white/10 px-5 py-4">
            <div>
              <h2 class="text-lg font-medium">Chat</h2>
              <p class="text-sm text-zinc-400">Interface inspirada no ChatGPT com atualizações parciais.</p>
            </div>
          </header>
          <div id="messages" class="flex-1 space-y-4 overflow-y-auto px-5 py-6">
            <%- include('partials/messages', { thread }) %>
          </div>
          <form
            class="border-t border-white/10 bg-black/20 p-4"
            hx-post="/chat"
            hx-target="#messages"
            hx-swap="innerHTML"
            hx-on::after-request="this.reset(); document.getElementById('messages').scrollTop = document.getElementById('messages').scrollHeight;"
          >
            <div class="flex gap-3">
              <input
                name="prompt"
                autocomplete="off"
                placeholder="Digite uma mensagem..."
                class="min-w-0 flex-1 rounded-2xl border border-white/10 bg-zinc-950 px-4 py-3 text-sm outline-none transition placeholder:text-zinc-500 focus:border-sky-400"
              />
              <button class="rounded-2xl bg-sky-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-400">
                Enviar
              </button>
            </div>
          </form>
        </section>
      </section>
    </main>
  </body>
</html>
